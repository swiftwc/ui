{
  "name": "@swiftwc/ui",
  "version": "0.0.0-dev.3",
  "description": "Elegant SwiftUI-inspired web components for ambitious web apps and web extensions.",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": {
    "name": "The SwiftWC/UI Authors",
    "url": "https://github.com/swiftwc/ui/graphs/contributors"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swiftwc/ui.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/swiftwc/ui/issues"
  },
  "files": [
    "generated",
    "scss"
  ],
  "sass": "scss/index.scss",
  "keywords": [
    "components",
    "ui",
    "swift"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./generated/index.d.ts",
      "default": "./generated/index.js"
    },
    "./components": {
      "types": "./generated/components/index.d.ts",
      "default": "./generated/components/index.js"
    },
    "./client": {
      "types": "./generated/client/index.d.ts",
      "default": "./generated/client/index.js"
    },
    "./styles.css": "./generated/styles.css",
    "./scss": "./scss/index.scss",
    "./scss/*": "./scss/*.scss"
  },
  "bin": {
    "swiftwc": "./generated/index.js"
  },
  "scripts": {
    "prebuild": "rm -rf generated",
    "build": "npm run build:ts && npm run build:scss",
    "build:ts:watch": "tsc --watch",
    "build:ts": "tsc",
    "build:scss": "sass --no-source-map scss/index.scss generated/styles.css",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "sass": "^1.97.2"
  }
}
