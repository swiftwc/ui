{
  "name": "@swiftwc/eslint-plugin",
  "version": "1.1.2",
  "description": "Rules enforcing best practices while using SwiftWC.",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "license": "SEE LICENSE IN ../../LICENSE.md",
  "author": {
    "name": "The SwiftWC/UI Authors",
    "url": "https://github.com/swiftwc/ui/graphs/contributors"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swiftwc/ui.git",
    "directory": "packages/eslint-plugin"
  },
  "bugs": {
    "url": "https://github.com/swiftwc/ui/issues"
  },
  "type": "module",
  "peerDependencies": {
    "@swiftwc/ui": "*",
    "eslint": ">=10.0.0"
  },
  "exports": {
    "./html/en": "./generated/html/en.js",
    "./emberjs/en": "./generated/emberjs/en.js"
  },
  "scripts": {
    "prebuild": "rm -rf generated",
    "build": "npm run build:ts",
    "build:ts:watch": "npm run prebuild && tsc --watch",
    "build:ts": "tsc",
    "format:check": "prettier . --check",
    "format:write": "prettier . --write"
  },
  "devDependencies": {
    "@typescript-eslint/utils": "^8.59.2"
  }
}
